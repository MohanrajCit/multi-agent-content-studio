# ── App ──────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=true

# ── Database ─────────────────────────────────────────
# async driver (asyncpg) for app + worker
DATABASE_URL=postgresql+asyncpg://studio:studio@postgres:5432/studio
# sync driver for Alembic migrations
DATABASE_URL_SYNC=postgresql+psycopg://studio:studio@postgres:5432/studio

# ── Redis (ARQ broker + SSE pub/sub) ─────────────────
REDIS_URL=redis://redis:6379/0

# ── LLM provider ─────────────────────────────────────
# Switch the entire platform with this one line: gemini | openrouter
LLM_PROVIDER=gemini

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-opus-4

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.5-pro

SERPER_API_KEY=
FIRECRAWL_API_KEY=

# ── Langfuse ─────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Single-tenant seeded user ────────────────────────
DEFAULT_USER_EMAIL=default@studio.local
DEFAULT_USER_NAME=Default User
